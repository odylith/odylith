%% Reviewed 2026-04-10 for B-025 to make the governed Compass refresh contract explicitly push-first, local-first, and zero-foreground-provider.
flowchart TB
  subgraph Entry["1. Operator Entry"]
    Prose["Operator opens Compass or asks for refresh"]
    CLI["odylith compass refresh<br/>odylith compass watch-transactions"]
    OneLane["One bounded refresh contract only<br/>no second deep or minute-scale lane"]
  end

  subgraph Detect["2. Change Detection"]
    Push["Best path: context-engine daemon waits on projection change<br/>watchman -> watchdog -> git-fsmonitor"]
    LocalWatch["Daemon absent: watch-transactions reuses the same local watcher stack directly"]
    Coarse["Last resort only: coarse polling on machines with no real watcher backend"]
    Fingerprint["Projection fingerprint changes?"]
    NoChange["No change -> no refresh, no provider call, no narration spend"]
  end

  subgraph Refresh["3. Shell-Safe Refresh"]
    Request["One shell-safe request"]
    Reuse{"Exact runtime payload still matches?"}
    Hot["Hot path reuse<br/>rewrite current snapshot cheaply"]
    Cold["Cold path local rebuild<br/>inputs -> events -> window facts -> payload write"]
    NoProvider["Foreground provider spend is zero"]
  end

  subgraph Briefs["4. Foreground Brief Selection"]
    Exact{"Exact same-packet brief cache exists?"}
    ExactHit["Use exact narrated cache<br/>global or scoped"]
    ScopedWarm{"Scoped brief missing but governed global live brief ready?"}
    Borrow["Show global live brief with an explicit scoped-warming notice"]
    Unavailable["Otherwise show explicit truthful unavailable state"]
  end

  subgraph Sidecar["5. Background Narration Maintenance"]
    Enqueue["Enqueue only missing packet entries for this new fingerprint"]
    Dedupe["Dedupe by fingerprint, runtime input fingerprint, and active worker"]
    Batch["One narrated bundle per new packet fingerprint<br/>global windows + verified scoped briefs together"]
    Retry["Provider failures get explicit reason + slow backoff<br/>capacity, budget, timeout, invalid batch"]
    Patch{"Runtime input fingerprint still matches current snapshot?"}
    PatchYes["Patch in warmed provider/cache brief"]
    PatchNo["Do not patch newer truth"]
  end

  subgraph Targets["6. Product Guardrails"]
    Budget["Targets<br/>hot exact reuse <= 50ms internal<br/>cold shell-safe <= 1s wall"]
    Truth["Rules<br/>no timer-led normal freshness loop<br/>no foreground provider narration<br/>no non-exact cache carry-forward"]
  end

  Prose --> CLI --> OneLane
  OneLane --> Push
  OneLane --> LocalWatch
  OneLane --> Coarse
  Push --> Fingerprint
  LocalWatch --> Fingerprint
  Coarse --> Fingerprint
  Fingerprint -->|No| NoChange
  Fingerprint -->|Yes| Request

  Request --> Reuse
  Reuse -->|Yes| Hot --> NoProvider
  Reuse -->|No| Cold --> NoProvider

  NoProvider --> Exact
  Exact -->|Yes| ExactHit
  Exact -->|No| ScopedWarm
  ScopedWarm -->|Yes| Borrow
  ScopedWarm -->|No| Unavailable

  Cold --> Enqueue
  Borrow --> Enqueue
  Unavailable --> Enqueue
  Enqueue --> Dedupe --> Batch --> Retry --> Patch
  Patch -->|Yes| PatchYes
  Patch -->|No| PatchNo

  OneLane --> Budget
  OneLane --> Truth

  classDef note fill:#f5f9ff,stroke:#7aa0d6,color:#1f355f
