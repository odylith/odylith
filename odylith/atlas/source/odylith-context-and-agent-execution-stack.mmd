        Contracts["Memory Contracts<br/>allowlist + compaction + execution-profile tokens"]
        Bundle --> Backend
        Bundle --> Remote
        Bundle --> Contracts
        MemorySnapshot --> Contracts
        Backend --> Contracts
        Remote --> Contracts
        SessionStream --> Contracts
    end

    Context --> Bundle
    Context --> MemorySnapshot
    Guidance["Guidance Behavior runtime<br/>compact corpus summary + validator command<br/>runtime-layer contract + Tribunal-ready signal"]
