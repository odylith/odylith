%% Reviewed 2026-03-26 for B-001 to show the self-governed Odylith product layers, explicit local memory/retrieval, governed surfaces, and optional remote augmentation seams.
flowchart TD
    subgraph Repo["Odylith Product Repository"]
        Truth["Tracked repo truth<br/>odylith/radar/source | odylith/technical-plans | odylith/casebook/bugs | odylith/atlas/source"]
        Contracts["contracts/<br/>component + packet contracts"]
        Docs["docs/<br/>product specs + runbooks + design notes"]
        RuntimeState[".odylith/<br/>local mutable runtime state"]
    end

    subgraph Product["Local-First Odylith Product"]
        CLI["odylith CLI<br/>install / upgrade / sync / doctor"]
        Context["context engine<br/>grounding + packets + retained handoff"]
        Memory["memory layer<br/>Lance/Tantivy + optional sparse recall seam"]
        Governance["governance engine<br/>delivery intelligence + registry + sync"]
        Evaluation["evaluation engine<br/>tribunal + remediator + benchmark/proof"]
        Agents["agent control<br/>router + orchestrator + host payloads"]
        Surfaces["governed surfaces<br/>Dashboard + Radar + Atlas + Compass + Registry + Casebook"]
    end

    subgraph OptionalRemote["Optional Remote Augmentation"]
        Recall["shared recall service<br/>optional sparse/hybrid augmentation"]
        Control["control attach<br/>optional approvals + dispatch + audit"]
    end

    Truth --> Context
    Truth --> Governance
    Contracts --> Context
    Contracts --> Evaluation
    Docs --> Surfaces
    CLI --> Context
    CLI --> Memory
    CLI --> Governance
    CLI --> Evaluation
    CLI --> Agents
    CLI --> Surfaces

    Context --> Memory
    Memory --> Governance
    Memory --> Evaluation
    Memory --> Agents
    Governance --> Surfaces
    Evaluation --> Surfaces
    Agents --> Surfaces

    Memory --> RuntimeState
    Governance --> RuntimeState
    Evaluation --> RuntimeState
    Agents --> RuntimeState

    Memory -. optional .-> Recall
    Surfaces -. optional .-> Control
    Control -. audit / dispatch .-> Evaluation
