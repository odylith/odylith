%% Reviewed 2026-04-17 for v0.1.11 after Context Engine, Execution Engine, visible-intervention, memory, Tribunal, and full-product assistance proof were aligned under accuracy-first benchmark gates.
flowchart LR
    subgraph Truth["1. Benchmark source truth"]
        Corpus["Benchmark corpus<br/>canonical scenarios + architecture_scenarios<br/>odylith/runtime/source/optimization-evaluation-corpus.v1.json"]
        BenchmarkSpec["Benchmark component spec<br/>odylith/registry/source/components/benchmark/CURRENT_SPEC.md"]
        GuidanceManifest["Canonical guidance manifest<br/>odylith/agents-guidelines/indexable-guidance-chunks.v1.json<br/>family-tagged benchmark guidance"]
        Workstreams["Radar benchmark workstreams<br/>B-009 + B-019 + B-020 + B-021 + B-022 + B-092 + B-093"]
        Validators["Public validator contract<br/>documented `odylith ...` entrypoints<br/>stay trustworthy for proof"]
        Taxonomy["Developer-first family taxonomy<br/>README + proof/diagnostic heatmaps<br/>ordered for developer legibility"]
        Seriousness["Seriousness floor<br/>60 implementation scenarios<br/>35 write+validator + 12 correctness-critical<br/>mechanism-heavy share <= 40%"]
        ExecutionScenarios["Execution + visibility scenarios<br/>route-ready + narrowing + verify-first<br/>recover-first + consumer lane + wait/resume<br/>hard correction + unsafe closure + host parity"]
    end

    subgraph Runtime["2. Benchmark execution lanes"]
        Runner["odylith benchmark<br/>runner + report contract<br/>event-stream result recovery + bounded adoption-proof finalizer"]
        GuidanceCatalog["Guidance catalog + family-hint retrieval<br/>non-empty benchmark preflight required"]
        Snapshot["Scoped shared snapshot<br/>same task-relevant repo truth for both lanes<br/>same-package dirty Python siblings included when needed"]
        Boundaries["Family-aware packet ceilings<br/>required_paths authoritative on grounded proof slices"]
        Determinism["Deterministic doc/test/command tie-breaks<br/>warm and cold choose the same truthful slice"]
        Proof["Proof lane<br/>full-product assistance vs raw-agent matched pair<br/>slice-relevant docs + strict bounded no-widen"]
        Diagnostic["Diagnostic lane<br/>packet/prompt-only internal tuning"]
        LocalMemory["Local memory first<br/>LanceDB + Tantivy active<br/>Vespa optional and disabled for published proof"]
        Warm["Warm cache profile"]
        Cold["Cold cache profile"]
        OdylithOn["odylith_on<br/>full Odylith assistance stack<br/>grounding + execution posture + bounded orchestration"]
        RawAgent["odylith_off / raw_agent_baseline<br/>same host CLI with Odylith assistance disabled"]
        ContextHandshake["Context Engine handshake<br/>packet quality + route readiness + target resolution"]
        ExecutionSnapshot["Execution Engine snapshot<br/>admissibility + mode + next move + closure<br/>wait/resume + validation + host carry-through"]
        InterventionProof["Visible intervention proof<br/>Observation / Proposal / Assist transcript harness<br/>hidden hook payloads do not count"]
        TribunalMemory["Memory + Tribunal influence<br/>session stream + proof ledger + rival diagnosis"]
    end

    subgraph Publication["3. Conservative publication view"]
        Probe["Sensitive singleton rerun probes<br/>same-profile median-of-N only when stability clears"]
        Breakdown["Time-to-valid-outcome breakdown<br/>live runtime + validator overhead + pair-wall totals"]
        Restore["Scoped validator truth restore<br/>restore stripped guidance from snapshot stash only<br/>never ambient repo root"]
        Fairness["Fairness contract<br/>declared lane affordances + raw prompt-visible anchors<br/>preflight evidence logged or fail closed"]
        PromptAudit["Prompt and corpus anomaly audit<br/>browser + install + release weak-family repair loop"]
        WeakFamilies["Pass-recovery weak-family loop<br/>component_governance + compass_brief_freshness<br/>consumer_profile + daemon_security + cross_file_feature"]
        ProofPublished["Published proof view<br/>same-profile same-scenario worst-case across warm + cold<br/>published_summary + family_deltas + robustness_summary"]
        DiagnosticPublished["Diagnostic mechanism snapshot<br/>packet/prompt-only report view"]
        AccuracyMetrics["Accuracy gates first<br/>snapshot presence + admissibility + mode<br/>truthful next move + closure + validation<br/>false-admit / false-deny + re-anchor + delegation guard"]
        CostMetrics["Efficiency gates second<br/>packet build time + snapshot time<br/>prompt/runtime tokens + total payload tokens"]
        LatestProof["latest-proof.v1.json / latest.v1.json"]
        LatestDiagnostic["latest-diagnostic.v1.json"]
        Graphs["Canonical graph renderer<br/>docs/benchmarks/proof/*.svg + diagnostic/*.svg"]
    end

    subgraph Release["4. Maintainer proof and public claim"]
        README["README benchmark snapshot"]
        ReleaseGuidance["Maintainer benchmark release guidance"]
        FirstReleaseBaseline["First shipped release baseline<br/>docs/benchmarks/release-baselines.v1.json<br/>benchmark_compare warns until recorded"]
        ReleaseGate["Release-ready benchmark proof<br/>full-product assistance vs raw-agent comparison"]
    end

