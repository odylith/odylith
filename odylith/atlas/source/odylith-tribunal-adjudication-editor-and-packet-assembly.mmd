%% Reviewed 2026-03-30 for provider-breaker and explicit deterministic fallback behavior before release proof.
flowchart LR
  subgraph Intake["1. Dossier intake"]
    Subject["Subject + decision at stake"]
    Observations["Observations<br/>owned artifacts, semantic-diff candidates,<br/>changed artifacts, code refs, proof routes, evidence gaps"]
    Evidence["Named evidence items"]
    Dossier["Grounded Tribunal dossier"]
  end

  subgraph Actors["2. Actor pass"]
    Observer["Observer"]
    Ownership["Ownership Resolver"]
    Causal["Causal Analyst"]
    Policy["Policy Judge"]
    Normative["Normative Judge"]
    Adversary["Adversary"]
    Counterfactual["Counterfactual Analyst"]
    Gap["Gap Analyst"]
    Risk["Risk Analyst"]
    Prescriber["Prescriber"]
  end

  subgraph Adjudication["3. Adjudication + provider validation"]
    Judge["Adjudicator<br/>form, leading story, rival, risk,<br/>next check, confidence factors"]
    Provider["Optional provider refinement<br/>OpenAI-compatible or codex exec"]
    Validate["Tribunal validator<br/>bounded fields + named evidence ids only"]
    Fallback["Deterministic fallback"]
    Breaker["Run-scoped provider breaker<br/>disable remaining provider attempts after timeout or transport failure"]
    Hybrid["Validated refined fields<br/>provider_used / provider_validated"]
  end

  subgraph Editorial["4. Editorial merge"]
    Editor["Editor<br/>queue headline + concise lead brief"]
    Systemic["Systemic brief<br/>shared latent causes across cases"]
    QueueRow["Case queue row<br/>headline, brief, reasoning_state,<br/>proof_routes, selection rationale"]
  end

  subgraph Action["5. Packet assembly and control loop"]
    Packet["compile_correction_packet()<br/>deterministic | ai_engine | hybrid | manual"]
    Ledger["decisions.v1.jsonl<br/>approve / delegate / apply / clear / dismiss"]
    Posture["sync_workstream_artifacts merge<br/>packet status + clearance state"]
    Surface["Odylith UI + CLI"]
  end

  Subject --> Dossier
  Observations --> Dossier
  Evidence --> Dossier

  Dossier --> Observer
  Dossier --> Ownership
  Dossier --> Causal
  Dossier --> Policy
  Dossier --> Normative
  Dossier --> Adversary
  Dossier --> Counterfactual
  Dossier --> Gap
  Dossier --> Risk
  Dossier --> Prescriber

  Observer --> Judge
  Ownership --> Judge
  Causal --> Judge
  Policy --> Judge
  Normative --> Judge
  Adversary --> Judge
  Counterfactual --> Judge
  Gap --> Judge
  Risk --> Judge
  Prescriber --> Judge

  Judge --> Provider
  Provider --> Validate
  Validate -- "valid" --> Hybrid
  Validate -- "timeout / transport / missing evidence / invalid fields" --> Fallback
  Judge --> Fallback
  Breaker -. governs remaining provider attempts .-> Provider
  Hybrid --> Editor
  Fallback --> Editor

  Judge --> Systemic
  Editor --> QueueRow
  Judge --> Packet
  QueueRow --> Surface
  Systemic --> Surface
  Packet --> Ledger
  Ledger --> Posture
  Posture --> Surface
